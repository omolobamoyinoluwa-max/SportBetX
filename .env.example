# SportBetX Environment Configuration
# Copy this file to .env and update with your values

# Application
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://sportbetx:sportbetx123@localhost:5432/sportbetx
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
BCRYPT_ROUNDS=12

# Stellar Configuration
STELLAR_NETWORK=testnet
STELLAR_CONTRACT_ADDRESS=your-contract-address-here
STELLAR_SECRET_KEY=your-stellar-secret-key-here
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Frontend URLs
FRONTEND_URL=http://localhost:3100
BETTING_INTERFACE_URL=http://localhost:3100
LIVE_BETTING_URL=http://localhost:3200
LIQUIDITY_DASHBOARD_URL=http://localhost:3300
ANALYTICS_DASHBOARD_URL=http://localhost:3400
GOVERNANCE_UI_URL=http://localhost:3500

# Sports Betting Configuration
PLATFORM_FEE_PERCENTAGE=200
MIN_BET_AMOUNT=1000000
MAX_BET_AMOUNT=100000000
DEFAULT_MIN_BET_AMOUNT=1000000
DEFAULT_MAX_BET_AMOUNT=100000000

# Odds Configuration
MIN_ODDS=1000
MAX_ODDS=1000000
DEFAULT_MAX_PARLAY_SIZE=8
MAX_PARLAY_SIZE=10
MAX_TIME_ADJUSTMENT=500

# Liquidity Pool Configuration
MIN_LIQUIDITY=10000000
MAX_LIQUIDITY=10000000000
DEFAULT_LIQUIDITY_PROVIDER_SHARE=7000
PLATFORM_LIQUIDITY_SHARE=3000

# Oracle Configuration
MIN_ORACLE_VOTES=3
DEFAULT_ORACLE_THRESHOLD=66
ORACLE_VOTING_PERIOD=3600
MAX_ORACLE_PROVIDERS=10
SPORTS_DATA_API_KEY=your-sports-data-api-key

# Governance Configuration
VOTING_PERIOD=604800
QUORUM_REQUIREMENT=1000
PROPOSAL_THRESHOLD=500
MIN_VOTING_POWER=1000
GOVERNANCE_TOKEN_SUPPLY=10000000000

# Event Configuration
MIN_EVENT_DURATION=3600
MAX_EVENT_DURATION=2592000
DEFAULT_EVENT_DURATION=172800
MAX_BETTING_PERIOD=3600
SETTLEMENT_DELAY=3600

# Risk Management Configuration
MAX_EXPOSURE_PER_EVENT=100000000
MAX_EXPOSURE_PER_USER=10000000
DEFAULT_MAX_EXPOSURE_PER_EVENT=50000000
DEFAULT_MAX_EXPOSURE_PER_USER=5000000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=9091

# External Services
EMAIL_SERVICE_API_KEY=your-email-service-api-key
NOTIFICATION_SERVICE_URL=https://api.notificationservice.com
PUSH_NOTIFICATION_VAPID_PUBLIC_KEY=your-vapid-public-key
PUSH_NOTIFICATION_VAPID_PRIVATE_KEY=your-vapid-private-key
PUSH_NOTIFICATION_VAPID_EMAIL=your-email@example.com

# Development
ENABLE_CORS=true
ENABLE_DEBUG_LOGGING=true
ENABLE_SWAGGER=true

# Production (uncomment for production)
# NODE_ENV=production
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# ENABLE_DEBUG_LOGGING=false

# Smart Contract Addresses
BETTING_MARKET_CONTRACT=your-betting-market-contract-address
LIQUIDITY_POOL_CONTRACT=your-liquidity-pool-contract-address
GOVERNANCE_CONTRACT=your-governance-contract-address
ORACLE_CONTRACT=your-oracle-contract-address

# API Keys
COINGECKO_API_KEY=your-coingecko-api-key
SPORTS_DATA_API_KEY=your-sports-data-api-key
WEATHER_API_KEY=your-weather-api-key

# WebSocket Configuration
WEBSOCKET_PORT=3005
WEBSOCKET_PATH=/socket.io

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Market Configuration
MIN_MARKET_DEPTH=1000000
MAX_MARKET_SPREAD=500
DEFAULT_MARKET_SPREAD=200

# Quality Configuration
ORACLE_QUALITY_THRESHOLD=8000
LIQUIDITY_QUALITY_SCORE=10000
MIN_QUALITY_SCORE=0

# Fee Configuration
PLATFORM_FEE_SHARE=5000
LIQUIDITY_PROVIDER_SHARE=4000
TREASURY_SHARE=1000

# Amount Constants
ONE_XLM=10000000
MIN_DEPOSIT_AMOUNT=1000000
MAX_DEPOSIT_AMOUNT=10000000000

# Sport Types
SPORT_FOOTBALL=football
SPORT_BASKETBALL=basketball
SPORT_TENNIS=tennis
SPORT_BASEBALL=baseball
SPORT_HOCKEY=hockey
SPORT_SOCCER=soccer
SPORT_ESPORTS=esports

# Bet Types
BET_TYPE_MONEYLINE=moneyline
BET_TYPE_SPREAD=spread
BET_TYPE_TOTAL=total
BET_TYPE_PARLAY=parlay
BET_TYPE_PROP=prop

# Event Status
EVENT_STATUS_UPCOMING=upcoming
EVENT_STATUS_LIVE=live
EVENT_STATUS_FINISHED=finished
EVENT_STATUS_CANCELED=canceled
EVENT_STATUS_POSTPONED=postponed

# Time Constants
SECONDS_PER_MINUTE=60
SECONDS_PER_HOUR=3600
SECONDS_PER_DAY=86400
SECONDS_PER_WEEK=604800

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Security Configuration
ENABLE_RATE_LIMITING=true
ENABLE_CSP=true
ENABLE_HSTS=true
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3200,http://localhost:3300,http://localhost:3400,http://localhost:3500
